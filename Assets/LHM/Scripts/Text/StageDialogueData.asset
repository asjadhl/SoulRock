%YAML 1.1
%TAG !u! tag:unity3d.com,2011:
--- !u!114 &11400000
MonoBehaviour:
  m_ObjectHideFlags: 0
  m_CorrespondingSourceObject: {fileID: 0}
  m_PrefabInstance: {fileID: 0}
  m_PrefabAsset: {fileID: 0}
  m_GameObject: {fileID: 0}
  m_Enabled: 1
  m_EditorHideFlags: 0
  m_Script: {fileID: 11500000, guid: 44cd37b001d9d034ba736b13c4b59155, type: 3}
  m_Name: StageDialogueData
  m_EditorClassIdentifier: 
  stage1:
    dialogues:
    - text: "Boo! ...\uC544, \uAE5C\uC9DD \uB180\uB790\uC9C0? \uD5E4\uD5E4\u2026
        \uBBF8\uC548\u2026"
      sound: {fileID: 8300000, guid: ec7384c9a86ee0346830f7e553d74249, type: 3}
    - text: "Boo! \uBC18\uAC00\uC6CC.. \uB09C..\uC74C... \uB108\uB97C \uB3D5\uB294
        \uC720\uB839\uC774\uC57C ..\uC544\uB9C8\uB3C4"
      sound: {fileID: 8300000, guid: ec7384c9a86ee0346830f7e553d74249, type: 3}
    - text: ...
      sound: {fileID: 8300000, guid: ec7384c9a86ee0346830f7e553d74249, type: 3}
    - text: "\uC9C4\uC9DC\uC57C \uBBFF\uC5B4\uB3C4 \uB3FC..."
      sound: {fileID: 8300000, guid: ec7384c9a86ee0346830f7e553d74249, type: 3}
    - text: "Boo! \uBA3C\uC800 \uAC04\uB2E8\uD558\uAC8C \uC870\uC791\uC744 \uC54C\uB824\uC904\uAC8C.."
      sound: {fileID: 8300000, guid: ec7384c9a86ee0346830f7e553d74249, type: 3}
    - text: "\uC5D0\uC784\uC810 \uADFC\uCC98 \uC6D0\uC774 \uC810\uC810 \uC5D0\uC784\uC810\uC5D0
        \uAC00\uAE4C\uC6CC \uC9C8\uAC70\uC57C... \uADF8\uB54C \uD074\uB9AD\uC744
        \uD558\uBA74... \uCD1D\uC774 \uBC1C\uC0AC\uAC00 \uB420\uAC70\uC57C..."
      sound: {fileID: 8300000, guid: ec7384c9a86ee0346830f7e553d74249, type: 3}
    - text: "Boo! \uB9CC\uC57D \uC5D0\uC784\uC810\uC5D0 \uC6D0\uC744 \uBABB\uB9DE\uCD94\uBA74...
        \uC2DC\uAC04\uC774 \uC9C0\uB098\uBA74\uC11C.. \uCCB4\uB825\uC774 \uACC4\uC18D
        \uAE4E\uC774\uAC8C \uB3FC... \uC870\uC2EC\uD574\uC57C\uD574..."
      sound: {fileID: 8300000, guid: ec7384c9a86ee0346830f7e553d74249, type: 3}
    - text: "Boo! \uACF5\uACA9\uC744 \uB9DE\uAC70\uB098 \uC2DC\uAC04\uC774 \uC9C0\uB098\uC11C
        \uCCB4\uB825\uC774 0\uC774 \uB418\uBA74 \uAC8C\uC784\uC624\uBC84\uC57C..."
      sound: {fileID: 8300000, guid: ec7384c9a86ee0346830f7e553d74249, type: 3}
    - text: "\uADF8\uB9AC\uACE0... \uBAA8\uB4E0 \uC2A4\uD14C\uC774\uC9C0\uB294 \uBCF4\uC2A4\uC758
        \uACF5\uACA9\uC744 \uBC84\uD168\uC57C\uD574..."
      sound: {fileID: 8300000, guid: ec7384c9a86ee0346830f7e553d74249, type: 3}
    - text: ...
      sound: {fileID: 8300000, guid: ec7384c9a86ee0346830f7e553d74249, type: 3}
    - text: "\uADF8\uAC8C\uB2E4\uC57C... "
      sound: {fileID: 8300000, guid: ec7384c9a86ee0346830f7e553d74249, type: 3}
    - text: "\uC804\uD22C\uB97C \uC2DC\uC791\uD558\uAE30\uC804\uC5D0.. \uADF8\uB54C
        \uAC01 \uD328\uD134\uC744 \uC124\uBA85\uD574\uC904\uAC8C.."
      sound: {fileID: 8300000, guid: ec7384c9a86ee0346830f7e553d74249, type: 3}
  stage2:
    dialogues:
    - text: "Boo! \u2026\uC5B4\uC11C \uC640, \uC7AD\uC2A8"
      sound: {fileID: 8300000, guid: ec7384c9a86ee0346830f7e553d74249, type: 3}
    - text: "\uC774\uBC88 \uB140\uC11D\uC740 \uC870\uAE08.. \uD2B9\uC774\uD574..
        \uD2B8\uB7FC\uD504 \uCE74\uB4DC\uB97C \uB108\uBB34 \uC0AC\uB791\uD574"
      sound: {fileID: 8300000, guid: ec7384c9a86ee0346830f7e553d74249, type: 3}
    - text: "\uCE74\uB4DC \uBB38\uC591\uC73C\uB85C.. \uBAA8\uB4E0\uAC83\uC744 \uC815\uD574\uBC84\uB9AC\uC9C0.."
      sound: {fileID: 8300000, guid: ec7384c9a86ee0346830f7e553d74249, type: 3}
    - text: "Boo! \uBCF4\uC2A4 \uBA38\uB9AC\uC704\uC5D0 \uCE74\uB4DC \uBB38\uC591\uC774
        \uBCF4\uC77C\uAC70\uC57C.."
      sound: {fileID: 8300000, guid: ec7384c9a86ee0346830f7e553d74249, type: 3}
    - text: "\uD558\uD2B8.. \uD074\uB85C\uBC84.. \uC2A4\uD398\uC774\uB4DC... \uB2E4\uC774\uC544..
        \uBB38\uC591\uB9C8\uB2E4 \uD328\uD134\uC774 \uB2EC\uB77C\uC9C0\uB2C8 \uC870\uC2EC\uD574\uC57C\uD574.."
      sound: {fileID: 8300000, guid: ec7384c9a86ee0346830f7e553d74249, type: 3}
    - text: "\uD2B9\uD788 \uC2A4\uD0DD\uC774\uB780\uAC8C \uC788\uB294\uB370.. \uAF2D!
        ..\uAE30\uC5B5\uD574 "
      sound: {fileID: 8300000, guid: ec7384c9a86ee0346830f7e553d74249, type: 3}
    - text: "\uC2A4\uD0DD\uC774 7\uAC1C \uC313\uC774\uBA74 \uAD11\uB300\uAC00 \uB108\uB97C
        \uC8FD\uC77C\uAC70\uC57C..."
      sound: {fileID: 8300000, guid: ec7384c9a86ee0346830f7e553d74249, type: 3}
    - text: "Boo! \uBA3C\uC800 \uD558\uD2B8\uC57C.. \uC5EC\uB7EC \uBC15\uC2A4 \uC911..
        \uD558\uB098\uC758 \uBC15\uC2A4\uC5D0 \uC228\uC5B4\uC788\uB294 \uC090\uC5D0\uB85C\uB97C
        \uCC3E\uC544\uC57C\uD574.. "
      sound: {fileID: 8300000, guid: ec7384c9a86ee0346830f7e553d74249, type: 3}
    - text: "\uBC15\uC2A4\uB294 \uC2A4\uD0DD\uB9CC\uD07C \uB298\uC5B4\uB098\uB2C8\uAE4C
        \uC870\uC2EC\uD558\uACE0..."
      sound: {fileID: 8300000, guid: ec7384c9a86ee0346830f7e553d74249, type: 3}
    - text: "Boo! \uD074\uB85C\uBC84\uB294.. \uB3CC\uB9BC\uD310\uC774 \uB3CC\uC544\uAC08\uB54C
        -,0\uC744 \uB178\uB824\uC11C \uB9DE\uCDB0\uC57C\uD574.. +\uB294 \uC22B\uC790\uB9CC\uD07C
        \uC2A4\uD0DD\uC774 \uB298\uC5B4\uB0A0\uAEBC\uC57C.."
      sound: {fileID: 8300000, guid: ec7384c9a86ee0346830f7e553d74249, type: 3}
    - text: "Boo! \uC2A4\uD398\uC774\uB4DC\uB294 \uCE74\uB4DC\uAC00 \uB0A0\uB77C\uC640..
        \uADF8\uAC78 \uB9DE\uCDB0\uC11C \uC3F4\uC57C\uD574.. \uB9DE\uC73C\uBA74..
        \uAE30\uB300\uD574\uB3C4 \uC88B\uC744\uAC70\uC57C.."
      sound: {fileID: 8300000, guid: ec7384c9a86ee0346830f7e553d74249, type: 3}
    - text: "Boo! \uB2E4\uC774\uC544\uB294.. \uBCF4\uC2A4\uAC00 \uD154\uD3EC\uD558\uB294\uB370
        \uBCF4\uC2A4\uB97C 5\uBC88\uC744 \uB9DE\uCDB0\uC57C.. \uB108\uAC00 \uC548\uC544\uD50C\uAC70\uC57C.."
      sound: {fileID: 0}
    - text: "Boo! \uADF8\uB7FC.. \uC774\uAE30\uAE38 \uBE4C\uAC8C... \uD750\uD750.."
      sound: {fileID: 8300000, guid: ec7384c9a86ee0346830f7e553d74249, type: 3}
  stage3:
    dialogues:
    - text: "Boo! \uB300\uB2E8\uD55C\uB370.. \uC5ED\uC2DC \uB108\uB77C\uBA74 \uC798\uD574\uB0BC
        \uC904 \uC54C\uC558\uC5B4.."
      sound: {fileID: 8300000, guid: ec7384c9a86ee0346830f7e553d74249, type: 3}
    - text: "\uC774\uBC88\uB140\uC11D\uC740 \uC544\uC8FC \uC704\uD5D8\uD574.. \uADF8\uB294.. "
      sound: {fileID: 8300000, guid: ec7384c9a86ee0346830f7e553d74249, type: 3}
    - text: "\uC544.. \uC544\uB2C8\uC9C0.. \uADF8\uAC83\uC740 \uB77D\uC744 \uC2EB\uC5B4\uD574..
        \uC0AC\uB78C\uB3C4 \uC8FD\uC77C\uC815\uB3C4\uB85C.."
      sound: {fileID: 8300000, guid: ec7384c9a86ee0346830f7e553d74249, type: 3}
    - text: "\uC2DC\uB044\uB7FD\uACE0! \uBD88\uC548\uD558\uACE0! \uC0C1\uC0C1\uB9CC\uD574\uB3C4
        \uBBF8\uCE60\uAC70\uAC19\uC544"
      sound: {fileID: 8300000, guid: ec7384c9a86ee0346830f7e553d74249, type: 3}
    - text: ...
      sound: {fileID: 8300000, guid: ec7384c9a86ee0346830f7e553d74249, type: 3}
    - text: "Boo! \uC544.. \uBBF8\uC548.. \uADF8\uB140\uC11D\uC774 \uC790\uC8FC\uD558\uB294\uB9D0\uC774\uB77C
        \uC2E0\uACBD\uC548\uC368\uB3C4 \uB3FC.. \uC808\uB300 \uB0B4\uAC00 \uD558\uACE0\uC2F6\uC740
        \uB9D0\uC774 \uC544\uB2C8\uC57C.."
      sound: {fileID: 8300000, guid: ec7384c9a86ee0346830f7e553d74249, type: 3}
    - text: "\uC774\uBC88\uC5D0\uB3C4 \uC124\uBA85\uD574\uC904\uAC8C.. \uC798 \uAE30\uC5B5\uD574.."
      sound: {fileID: 8300000, guid: ec7384c9a86ee0346830f7e553d74249, type: 3}
    - text: "Boo! \uAC00\uC6B4\uB370 \uC5D0\uB108\uC9C0\uAC00 \uBAA8\uC774\uBA74
        \uAF2D \uCD1D\uC73C\uB85C \uC3F4\uC11C \uC5C6\uC560\uC57C\uD574.."
      sound: {fileID: 8300000, guid: ec7384c9a86ee0346830f7e553d74249, type: 3}
    - text: "Boo! \uBCF4\uC2A4\uAC00 \uC8FC\uBCC0\uC5D0 \uC5D0\uB108\uC9C0 \uD0C4\uC744
        \uB9C9 \uBFCC\uB9B4\uAC70\uC57C.. \uBFCC\uB9B0..\uC21C\uC11C\uB300\uB85C
        \uB108\uC5D0\uAC8C \uB0A0\uC544 \uAC00\uB2C8\uAE4C.. \uAF2D \uC798 \uB9DE\uCDB0\uC11C
        \uC5C6\uC560\uC57C \uD558\uACE0..."
      sound: {fileID: 8300000, guid: ec7384c9a86ee0346830f7e553d74249, type: 3}
    - text: "Boo! \uBCF4\uC2A4\uAC00 \uD558\uB298\uC704\uC5D0\uC11C \uC5D0\uB108\uC9C0\uB97C
        \uBAA8\uC73C\uBA74 \uAC70\uC6B8\uC774 \uC0DD\uAE38\uAC70\uC57C.. \uADF8 \uAC70\uC6B8\uC744
        \uC3F4\uC11C \uBCF4\uC2A4\uCABD\uC73C\uB85C \uD5A5\uD558\uAC8C \uAC01\uB3C4\uB97C
        \uB9DE\uCD94\uBA74 \uC5D0\uB108\uC9C0\uAC00 \uBC18\uC0AC\uB420\uAC70\uC57C.."
      sound: {fileID: 8300000, guid: ec7384c9a86ee0346830f7e553d74249, type: 3}
    - text: "Boo! \uBCF4\uC2A4 \uD53C\uAC00 30% \uC544\uB798\uB85C \uB5A8\uC5B4\uC9C0\uBA74
        \uBCF4\uC2A4\uAC00 \uBE68\uAC1C\uC9C0\uACE0 \uC8FC\uBCC0\uC5D0 \uC791\uC740
        \uC560\uB4E4\uC774 \uB110 \uACF5\uACA9\uD558\uACE0 \uBCF4\uC2A4 \uD328\uD134\uB4E4\uC774
        \uAC15\uD654\uB3FC \uAF2D \uC870\uC2EC\uD574..."
      sound: {fileID: 8300000, guid: ec7384c9a86ee0346830f7e553d74249, type: 3}
  stage4:
    dialogues:
    - text: "Boo.. \uC5B4\uC11C\uC640.. \uD798\uB4E0\uC77C\uC774 \uC880 \uB9CE\uC558\uC9C0..?"
      sound: {fileID: 8300000, guid: ec7384c9a86ee0346830f7e553d74249, type: 3}
    - text: "\uC7AD\uC2A8.. \uB108 \uB355\uBD84\uC5D0 \uB0B4 \uD560\uC77C\uC774 \uC904\uC5B4\uB4E4\uC5C8\uC5B4..
        \uACE0\uB9C8\uC6CC.."
      sound: {fileID: 8300000, guid: ec7384c9a86ee0346830f7e553d74249, type: 3}
    - text: "\uADFC\uB370 \uC774\uC81C \uC815\uB9D0 \uC911\uC694\uD55C \uC77C\uC774
        \uD558\uB098 \uB0A8\uC544\uC788\uC5B4.."
      sound: {fileID: 8300000, guid: ec7384c9a86ee0346830f7e553d74249, type: 3}
    - text: "Boo.. \uC561\uC790 \uCABD\uC73C\uB85C \uAC00\uAE4C\uC774 \uC640\uC904\uB808..?"
      sound: {fileID: 8300000, guid: ec7384c9a86ee0346830f7e553d74249, type: 3}
  stage5:
    dialogues:
    - text: "Boo! \uBB58 \uADF8\uB9AC \uB180\uB77C \uB098\uB3C4 \uC545\uB839\uC778\uAC83\uC744
        \uC78A\uC740\uAC70\uC57C?"
      sound: {fileID: 8300000, guid: ec7384c9a86ee0346830f7e553d74249, type: 3}
    - text: "\uCC98\uC74C\uC5D0\uB294 \uB77D\uC744 \uBE8F\uACE0 \uB3CC\uB824\uC904\uB824\uB294
        \uC77C\uC885\uC758 \uC7A5\uB09C \uC774\uC600\uC9C0\uB9CC.. \uADF8\uB7F4\uC0DD\uAC01\uC774
        \uC0AC\uB77C\uC84C\uC5B4 "
      sound: {fileID: 8300000, guid: ec7384c9a86ee0346830f7e553d74249, type: 3}
    - text: "\uBB34\uAE30\uB825\uD574\uC9C0\uACE0! \uC758\uC9C0\uB97C \uC783\uACE0!!
        \uC778\uC0DD\uC758 \uC804\uBD80\uC778\uAC83 \uB9C8\uB0E5 \uADF8\uB7F0 \uBC18\uC751\uC774
        \uB098\uB97C \uBBF8\uCE58\uAC8C\uD574"
      sound: {fileID: 8300000, guid: ec7384c9a86ee0346830f7e553d74249, type: 3}
    - text: "\uB355\uBD84\uC5D0 \uC561\uC790\uC18D\uC5D0 \uAC07\uD600\uC788\uB358
        \uBA4D\uCCAD\uC774\uB4E4 \uACFC\uB294 \uB2E4\uB974\uAC8C \uB09C \uC561\uC790\uC18D\uC5D0\uC11C\uB3C4
        \uD604\uC2E4 \uC138\uACC4\uC5D0\uC11C\uB3C4 \uC655\uC774 \uB418\uC5C8\uC5B4"
      sound: {fileID: 8300000, guid: ec7384c9a86ee0346830f7e553d74249, type: 3}
    - text: "\uC7AD\uC2A8 \uC815\uB9D0 \uACE0\uB9C8\uC6CC \uD2B9\uBCC4\uD788 \uB108\uAC00
        \uB0B4 \uCCAB \uC81C\uBB3C\uC774 \uB420\uC218\uC788\uB294 \uC601\uAD11\uC744
        \uC904\uAC8C"
      sound: {fileID: 8300000, guid: ec7384c9a86ee0346830f7e553d74249, type: 3}
