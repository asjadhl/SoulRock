  m_Script: {fileID: 11500000, guid: 44cd37b001d9d034ba736b13c4b59155, type: 3}
  m_Name: StageDialogueData
  m_EditorClassIdentifier: 
  stage1:
    dialogues:
    - text: "Boo! \u2026\uC544, \uAE5C\uC9DD \uB180\uB790\uC9C0? \uD5E4\uD5E4\u2026
        \uBBF8\uC548\u2026"
      sound: {fileID: 8300000, guid: ad43eb633782efb4dbf942932c60eee3, type: 3}
    - text: "Boo! \uBC18\uAC00\uC6CC\u2026 \uB09C\u2026 \uC74C\u2026 \uB108\uB97C
        \uB3D5\uB294 \uC720\uB839\uC774\uC57C ...\uC544\uB9C8\uB3C4"
      sound: {fileID: 8300000, guid: 2d5f21811c8b66342af5f2a1291f2795, type: 3}
    - text: ...
      sound: {fileID: 0}
    - text: "\uC9C4\uC9DC\uC57C \uBBFF\uC5B4\uB3C4 \uB3FC..."
      sound: {fileID: 8300000, guid: 144eb0291cec07843a923efdf3ab4b1c, type: 3}
    - text: "Boo! \uBA3C\uC800 \uAC04\uB2E8\uD558\uAC8C \uC870\uC791\uC744 \uC54C\uB824\uC904\uAC8C..."
      sound: {fileID: 8300000, guid: 725fa3a10fcb20d48aacfa5d5867309d, type: 3}
    - text: "\uC5D0\uC784\uC810 \uADFC\uCC98 \uC6D0\uC774 \uC810\uC810 \uC5D0\uC784\uC810\uC5D0
        \uAC00\uAE4C\uC6CC \uC9C8\uAC70\uC57C.. \uADF8\uB54C \uD074\uB9AD\uC744 \uD558\uBA74..
        \uCD1D\uC774 \uBC1C\uC0AC\uAC00 \uB420\uAC70\uC57C..."
      sound: {fileID: 8300000, guid: 4139f8aa8d0ad0349987f239288cf436, type: 3}
    - text: ...
      sound: {fileID: 0}
    - text: "\uADF8\uAC8C\uB2E4\uC57C... "
      sound: {fileID: 8300000, guid: 0a5ea9bed18886e41a16e7afbf3f9c1c, type: 3}
    - text: "\uC804\uD22C\uB97C \uC2DC\uC791\uD558\uBA74 \uADF8\uB54C \uAC01 \uD328\uD134\uC744
        \uC124\uBA85\uD574\uC904\uAC8C.."
      sound: {fileID: 8300000, guid: 6489d663c16f0f849bcc7db766fdb0f9, type: 3}
  stage2:
    dialogues: []
  stage3:
    dialogues: []
