  m_Name: DialogueData
  m_EditorClassIdentifier: Assembly-CSharp::StageDialogueData
  stage1:
    dialogues:
    - "Boo! \u2026\uC544, \uAE5C\uC9DD \uB180\uB790\uC9C0? \uD5E4\uD5E4\u2026 \uBBF8\uC548\u2026"
    - "Boo! \uBC18\uAC00\uC6CC\u2026 \uB09C\u2026 \uC74C\u2026 \uB108\uB97C \uB3D5\uB294
      \uC720\uB839\uC774\uC57C. \uC544\uB9C8\uB3C4.\n\uC624\uB298\uC740\u2026 \uB124
      \uCCAB \uBB34\uB300\uB2C8\uAE4C\u2026 \uB0B4\uAC00\u2026 \uC870\uAE08 \uB3C4\uC640\uC904\uAC8C."
    - "\u2026"
    - "\uC9C4\uC9DC\uC57C. \uBBFF\uC5B4\uB3C4 \uB3FC."
    - "\uBA3C\uC800 \uAC04\uB2E8\uD558\uAC8C \uBC29\uBC95\uC744 \uC54C\uB824\uC904\uAC8C.. "
    - "\uC6D0\uC774 \uC0AC\uB77C\uC9C0\uAE30\uC804 \uBC15\uC790\uC5D0 \uB9DE\uCDB0\uC11C
      \uD074\uB9AD\uC744 \uD574\uBD10.."
    - "\uADF8\uB7EC\uBA74 \uCD1D\uC774 \uB098\uAC08\uAC70\uC57C.."
    - "\uBAA8\uB4E0 \uBCF4\uC2A4 \uD328\uD134\uACFC \uACF5\uACA9\uB4E4\uC744 \uC3F4\uC11C
      \uB9C9\uC744 \uC218 \uC788\uC5B4.."
    - ...
    - "\uB09C.. \uAC08\uAC8C.."
  stage2:
    dialogues:
    - "\uC774\uBC88 \uBCF4\uC2A4\uB294.. \uAD11\uB300\uB4E4\uC774\uC57C.."
    - "\uB0B4\uAC00 \uBCF4\uC2A4\uC758 \uD328\uD134\uC744 \uC54C\uB824\uC904\uAC8C.."
    - "\uBCF4\uC2A4 \uBA38\uB9AC \uC704\uC5D0 \uCE74\uB4DC \uBB38\uC591\uC5D0 \uB530\uB77C
      \uD328\uD134\uC774 \uB2EC\uB77C\uC838.."
    - "\uD558\uD2B8\uB294..\uBC15\uC2A4 \uC228\uC5B4\uC788\uB294 \uAD11\uB300\uB97C
      \uCC3E\uC544\uC57C\uD574.."
    - "\uD074\uB85C\uBC84\uB294 \uB3CC\uB9BC\uD310\uC744 \uB9DE\uCD94\uC5B4\uC11C
      -,0\uCE78\uC744 \uB178\uB824\uC11C \uC2A4\uD0DD\uC774 \uC904\uC5B4\uB4E4\uAC8C
      \uD574\uC57C..\uD574.."
    - "\uC2A4\uD0DD\uC774 7\uAC1C \uC313\uC774\uBA74 \uC8FD\uC73C\uB2C8\uAE4C.. \uC870\uC2EC\uD558\uACE0.."
    - "\uC2A4\uD0DD\uC744 \uB9CE\uC774 \uC313\uC73C\uBA74 \uD2B9\uC815 \uAE30\uBBF9\uC758
      \uAC2F\uC218\uAC00 \uC62C\uB77C\uAC00.. \uC870\uC2EC\uD574.."
    - "\uC2A4\uD398\uC774\uB4DC\uB294 \uB0A0\uB77C\uC624\uB294 \uCE74\uB4DC\uB4E4\uC744
      \uB9DE\uCD94\uC5B4\uC11C \uB5A8\uC5B4\uB728\uB9AC\uACE0.."
    - "\uB9C8\uC9C0\uB9C9 \uB2E4\uC774\uC544\uB294 \uBCF4\uC2A4\uAC00 \uC21C\uAC04\uC774\uB3D9
      \uD560\uB54C 5\uBC88 \uD074\uB9AD\uD574\uC57C\uC9C0 \uACF5\uACA9\uC744 \uB9C9\uC744
      \uC218 \uC788\uC5B4.."
  stage3:
