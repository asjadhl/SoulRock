  m_Script: {fileID: 11500000, guid: e2b43658c38f1e94a9311d889addd178, type: 3}
  m_Name: TutorialTextData
  m_EditorClassIdentifier: 
  tutline1:
    tutorialLines:
    - text: "Boo! \u2026\uC544, \uAE5C\uC9DD \uB180\uB790\uC9C0? \uD5E4\uD5E4\u2026
        \uBBF8\uC548\u2026"
      sound: {fileID: 0}
    - text: "Boo! \uBC18\uAC00\uC6CC\u2026 \uB09C\u2026 \uC74C\u2026 \uB108\uB97C
        \uB3D5\uB294 \uC720\uB839\uC774\uC57C ...\uC544\uB9C8\uB3C4"
      sound: {fileID: 0}
    - text: ...
      sound: {fileID: 0}
    - text: "\uC9C4\uC9DC\uC57C \uBBFF\uC5B4\uB3C4 \uB3FC..."
      sound: {fileID: 0}
    - text: "Boo! \uBA3C\uC800 \uAC04\uB2E8\uD558\uAC8C \uC870\uC791\uC744 \uC54C\uB824\uC904\uAC8C..."
      sound: {fileID: 0}
    - text: "\uC5D0\uC784\uC810 \uADFC\uCC98 \uC6D0\uC774 \uC810\uC810 \uC5D0\uC784\uC810\uC5D0
        \uAC00\uAE4C\uC6CC \uC9C8\uAC70\uC57C.. \uADF8\uB54C \uD074\uB9AD\uC744 \uD558\uBA74..
        \uCD1D\uC774 \uBC1C\uC0AC\uAC00 \uB420\uAC70\uC57C..."
      sound: {fileID: 0}
    - text: "\uC774\uC81C \uD55C\uBC88.. \uC800 \uBE5B\uB098\uB294 \uB354\uBBF8\uB97C
        \uB9DE\uCDB0\uBD10..."
      sound: {fileID: 0}
    - text: "Boo! \uB531 2\uB300\uB9CC \uB9DE\uCDB0\uBCFC\uAE4C.."
      sound: {fileID: 0}
  tutline2:
    tutorialLines:
    - text: "\uC798\uD588\uC5B4.. \uC5ED\uC2DC \uB10C \uBB50\uB4E0 \uC798\uD558\uB294\uAD6C\uB098.."
      sound: {fileID: 0}
    - text: "\uB9CC\uC57D \uC5D0\uC784\uC810\uC5D0 \uC6D0\uC744 \uBABB\uB9DE\uCD94\uBA74...
        \uC2DC\uAC04\uC774 \uC9C0\uB098\uBA74\uC11C.. \uCCB4\uB825\uC774 \uACC4\uC18D
        \uAE4E\uC774\uAC8C \uB3FC... \uC870\uC2EC\uD574\uC57C\uD574... "
      sound: {fileID: 0}
    - text: "Boo! \uACF5\uACA9\uC744 \uB9DE\uAC70\uB098 \uC2DC\uAC04\uC774 \uC9C0\uB098\uC11C
        \uCCB4\uB825\uC774 0\uC774 \uB418\uBA74 \uAC8C\uC784\uC624\uBC84\uC57C..."
      sound: {fileID: 0}
    - text: "\uADF8\uB9AC\uACE0... \uBAA8\uB4E0 \uC2A4\uD14C\uC774\uC9C0\uB294 \uBCF4\uC2A4\uC758
        \uACF5\uACA9\uC744 \uBC84\uD168\uC57C\uD574..."
      sound: {fileID: 0}
    - text: ...
      sound: {fileID: 0}
    - text: "\uADF8\uAC8C\uB2E4\uC57C... "
      sound: {fileID: 0}
    - text: "\uC774\uC81C \uC900\uBE44\uAC00 \uB2E4 \uB41C \uAC83 \uAC19\uB124...
        \uC790, \uADF8\uB7FC \uBCF8\uACA9\uC801\uC73C\uB85C \uC2DC\uC791\uD574\uBCFC\uAE4C?"
      sound: {fileID: 0}
  tutline3:
    tutorialLines: []
  tutline4:
    tutorialLines: []
