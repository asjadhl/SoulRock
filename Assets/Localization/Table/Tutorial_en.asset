  m_Script: {fileID: 11500000, guid: e9620f8c34305754d8cc9a7e49e852d9, type: 3}
  m_Name: Tutorial_en
  m_EditorClassIdentifier: 
  m_LocaleId:
    m_Code: en
  m_SharedData: {fileID: 11400000, guid: 83d6a09bdaebd9a4180ceb65e5147e2c, type: 2}
  m_Metadata:
    m_Items: []
  m_TableData:
  - m_Id: 711487738417152
    m_Localized: "Boo! \u2026Ah, I scared you, didn\u2019t I? Hehe\u2026 Sorry about
      that\u2026"
    m_Metadata:
      m_Items: []
  - m_Id: 711490380828672
    m_Localized: "Boo! Nice to meet you\u2026 I\u2019m\u2026 well\u2026 I\u2019m
      a ghost that helps you\u2026 probably."
    m_Metadata:
      m_Items: []
  - m_Id: 711492696084480
    m_Localized: "It\u2019s true, you can trust me..."
    m_Metadata:
      m_Items: []
  - m_Id: 711495044894720
    m_Localized: "Boo! Let me quickly show you the controls\u2026"
    m_Metadata:
      m_Items: []
  - m_Id: 711497259487232
    m_Localized: "The circle near the aim point will gradually get closer to it.
      When it\u2019s right on the mark, click to fire your weapon..."
    m_Metadata:
      m_Items: []
  - m_Id: 711500010950656
    m_Localized: Now, try hitting that glowing target...
    m_Metadata:
      m_Items: []
  - m_Id: 711501990662144
    m_Localized: "Boo! Let\u2019s see if you can hit it just twice..."
    m_Metadata:
      m_Items: []
  - m_Id: 711503500611584
    m_Localized: "Nice job! You\u2019re really good at this!"
    m_Metadata:
      m_Items: []
  - m_Id: 711504909897728
    m_Localized: If you miss the aim point, though, your health will keep decreasing
      over time... so be careful..
    m_Metadata:
      m_Items: []
  - m_Id: 711506218520576
    m_Localized: "Boo! If you take too many hits or run out of time, you\u2019ll
      lose the game..."
    m_Metadata:
      m_Items: []
  - m_Id: 711507866882048
    m_Localized: "Also, in every stage, you\u2019ll have to survive the boss\u2019s
      attacks..."
    m_Metadata:
      m_Items: []
  - m_Id: 711509443940352
    m_Localized: "That\u2019s all for now..."
    m_Metadata:
      m_Items: []
  - m_Id: 711510886780928
    m_Localized: "Looks like you\u2019re ready. So, shall we start the real game?"
    m_Metadata:
      m_Items: []
  references:
    version: 2
    RefIds: []
