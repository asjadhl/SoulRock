  m_SharedData: {fileID: 11400000, guid: df8f4fb56f5db9d408b7bcba5096ace8, type: 2}
  m_Metadata:
    m_Items: []
  m_TableData:
  - m_Id: 8035586048
    m_Localized: "Why\u2026 why are we doing this?"
    m_Metadata:
      m_Items: []
  - m_Id: 70211948544
    m_Localized: "Do we even remember why we\u2019re trapped inside these frames\u2026?"
    m_Metadata:
      m_Items: []
  - m_Id: 123936788480
    m_Localized: "Jackson\u2026 the clown doesn\u2019t even understand why he\u2019s
      doing all this."
    m_Metadata:
      m_Items: []
  - m_Id: 128261115904
    m_Localized: "They\u2019ve forgotten their situation forever repeating meaningless
      actions within the frame."
    m_Metadata:
      m_Items: []
  - m_Id: 130580566016
    m_Localized: "We have to save them, Jackson\u2026"
    m_Metadata:
      m_Items: []
  - m_Id: 509108113408
    m_Localized: "You\u2019re so selfish. When something is lost, something else
      is gained."
    m_Metadata:
      m_Items: []
  - m_Id: 510550953984
    m_Localized: "You don\u2019t understand anything\u2026"
    m_Metadata:
      m_Items: []
  - m_Id: 511926685696
    m_Localized: "You don\u2019t even see what\u2019s standing right beside you\u2026"
    m_Metadata:
      m_Items: []
  - m_Id: 750192513024
    m_Localized: It all began as a prank to steal rock and gather power.
    m_Metadata:
      m_Items: []
  - m_Id: 751635353600
    m_Localized: But that power went far beyond my control.
    m_Metadata:
      m_Items: []
  - m_Id: 753178857472
    m_Localized: I thought I had become a true king...
    m_Metadata:
      m_Items: []
  - m_Id: 754990796800
    m_Localized: "But in the end\u2026 rock took all of my power away."
    m_Metadata:
      m_Items: []
  - m_Id: 756366528512
    m_Localized: Rock truly is something incredible...
    m_Metadata:
      m_Items: []
  references:
    version: 2
