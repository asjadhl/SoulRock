    m_Code: en
  m_SharedData: {fileID: 11400000, guid: df8f4fb56f5db9d408b7bcba5096ace8, type: 2}
  m_Metadata:
    m_Items: []
  m_TableData:
  - m_Id: 91384795136
    m_Localized: I just wanted to reclaim my stage...
    m_Metadata:
      m_Items: []
  - m_Id: 94035595264
    m_Localized: I was trapped inside the frame by a certain ghost...
    m_Metadata:
      m_Items: []
  - m_Id: 107558031360
    m_Localized: Thanks to you, I regained my freedom.
    m_Metadata:
      m_Items: []
  - m_Id: 109504188416
    m_Localized: But why... do I feel this presence coming from you?
    m_Metadata:
      m_Items: []
  - m_Id: 228710502400
    m_Localized: Be careful...
    m_Metadata:
      m_Items: []
  - m_Id: 580298035200
    m_Localized: I only despised rock...and yet, it's come to this.
    m_Metadata:
      m_Items: []
  - m_Id: 582273552384
    m_Localized: "You... don\u2019t understand anything."
    m_Metadata:
      m_Items: []
  - m_Id: 583452151808
    m_Localized: "You don\u2019t even realize what\u2019s right beside you..."
    m_Metadata:
      m_Items: []
  - m_Id: 762829950976
    m_Localized: I imprisoned them who hated rock... to gether power.
    m_Metadata:
      m_Items: []
  - m_Id: 764541227008
    m_Localized: The power of hatred surpassed even my expectations....
    m_Metadata:
      m_Items: []
  - m_Id: 765950513152
    m_Localized: I thought I had become a true king...
    m_Metadata:
      m_Items: []
  - m_Id: 767292690432
    m_Localized: But in the end, I lost all my power because of your rock power...
    m_Metadata:
      m_Items: []
  - m_Id: 768433541120
    m_Localized: Rock... it's far greater than I ever imagined.
    m_Metadata:
      m_Items: []
  - m_Id: 1024526464143360
    m_Localized: "Jackson\u2026 what\u2019s your last name?"
    m_Metadata:
      m_Items: []
  - m_Id: 1029800788840448
    m_Localized: ' '
    m_Metadata:
      m_Items: []
  references:
    version: 2
