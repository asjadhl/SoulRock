  m_Script: {fileID: 11500000, guid: e9620f8c34305754d8cc9a7e49e852d9, type: 3}
  m_Name: Tutorial_Dialogue_en
  m_EditorClassIdentifier: 
  m_LocaleId:
    m_Code: en
  m_SharedData: {fileID: 11400000, guid: 3eaa47c9ba1283a49bf442fb008c872f, type: 2}
  m_Metadata:
    m_Items: []
  m_TableData:
  - m_Id: 57121525760
    m_Localized: ...
    m_Metadata:
      m_Items: []
  - m_Id: 23097331712
    m_Localized: "Boo! \u2026Ah, did I scare you? Hehe\u2026 sorry about that."
    m_Metadata:
      m_Items: []
  - m_Id: 54336507904
    m_Localized: "Boo! Nice to meet you\u2026 I\u2019m, uh\u2026 your friendly ghost
      helper\u2026 probably."
    m_Metadata:
      m_Items: []
  - m_Id: 59269009408
    m_Localized: "It\u2019s true! You can trust me."
    m_Metadata:
      m_Items: []
  - m_Id: 61315829760
    m_Localized: Boo! First, let me teach you the basics.
    m_Metadata:
      m_Items: []
  - m_Id: 64771936256
    m_Localized: "You\u2019ll see a circle closing in toward your aim point\u2026
      When it gets close enough, click \u2014 and your gun will fire!"
    m_Metadata:
      m_Items: []
  - m_Id: 66646790144
    m_Localized: "Now, go on\u2026 try shooting that glowing dummy over there."
    m_Metadata:
      m_Items: []
  - m_Id: 68261597184
    m_Localized: "Boo! Let\u2019s say\u2026 just two hits, okay?"
    m_Metadata:
      m_Items: []
  - m_Id: 69670883328
    m_Localized: "Nice job! I knew you\u2019d be good at this."
    m_Metadata:
      m_Items: []
  - m_Id: 70916591616
    m_Localized: "If you miss the rhythm the circle and aim don\u2019t sync your
      health will slowly drain over time. Be careful!"
    m_Metadata:
      m_Items: []
  - m_Id: 72254574592
    m_Localized: "Boo! If your HP hits zero \u2014 either from enemy attacks or time
      \u2014 it\u2019s game over."
    m_Metadata:
      m_Items: []
  - m_Id: 73630306304
    m_Localized: "And remember\u2026 every stage is a battle to endure the boss\u2019s
      assault."
    m_Metadata:
      m_Items: []
  - m_Id: 74938929152
    m_Localized: ...
    m_Metadata:
      m_Items: []
  - m_Id: 76381769728
    m_Localized: "That\u2019s it!"
    m_Metadata:
      m_Items: []
  - m_Id: 77858164736
    m_Localized: "Looks like you\u2019re ready. Now then\u2026 shall we really get
      this show started?"
    m_Metadata:
      m_Items: []
  references:
    version: 2
    RefIds: []
